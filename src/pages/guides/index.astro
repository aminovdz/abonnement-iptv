---
import Layout from '../../layouts/Layout.astro';

const guides = [
	{
		title: "Comment installer l'IPTV sur Smart TV ?",
		description: "Guide étape par étape pour Samsung, LG et autres Smart TV.",
		slug: "installation-smart-tv",
		date: "2024-05-01"
	},
	{
		title: "Meilleures applications IPTV pour Android en 2024",
		description: "Top 5 des applications pour profiter de votre abonnement sur Android Box.",
		slug: "meilleures-apps-android",
		date: "2024-05-02"
	},
	{
		title: "Comment éviter les freezes sur IPTV ?",
		description: "Nos conseils techniques pour une stabilité parfaite.",
		slug: "eviter-freezes-iptv",
		date: "2024-05-03"
	}
];
---

<Layout title="Guides IPTV & Tutoriels - Tout savoir sur l'IPTV en France" description="Découvrez nos guides complets pour installer et optimiser votre abonnement IPTV sur tous vos appareils.">
	<section class="bg-slate-50 py-20">
		<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
			<h1 class="text-4xl font-extrabold text-slate-900">Guides & Tutoriels</h1>
			<p class="mt-4 text-xl text-slate-600">Apprenez à tirer le meilleur parti de votre service IPTV.</p>
		</div>
	</section>

	<section class="py-20 bg-white">
		<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
			<div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
				{guides.map((guide) => (
					<a href={`/guides/${guide.slug}`} class="group rounded-2xl border border-slate-100 bg-white p-6 shadow-sm transition hover:shadow-md">
						<div class="text-xs font-bold uppercase tracking-wider text-brand-blue">{guide.date}</div>
						<h2 class="mt-4 text-xl font-bold text-slate-900 group-hover:text-brand-blue">{guide.title}</h2>
						<p class="mt-2 text-slate-600">{guide.description}</p>
						<div class="mt-6 flex items-center font-bold text-brand-blue">
							Lire le guide <span class="ml-2 transition-transform group-hover:translate-x-1">→</span>
						</div>
					</a>
				))}
			</div>
		</div>
	</section>
</Layout>

---
import Layout from '../../layouts/Layout.astro';

export function getStaticPaths() {
	const guides = [
		{
			slug: "installation-smart-tv",
			title: "Comment installer l'IPTV sur Smart TV ?",
			content: `
				<h2>Introduction</h2>
				<p>Installer l'IPTV sur votre Smart TV Samsung ou LG est un processus simple qui prend moins de 5 minutes.</p>
				<h2>Étapes d'installation</h2>
				<ol>
					<li>Allumez votre Smart TV et accédez à la boutique d'applications (App Store).</li>
					<li>Recherchez une application comme <strong>IBO Player</strong>, <strong>Smarters Player Lite</strong> ou <strong>Smart IPTV</strong>.</li>
					<li>Téléchargez et ouvrez l'application.</li>
					<li>Notez l'adresse MAC affichée à l'écran.</li>
					<li>Envoyez-nous cette adresse MAC sur WhatsApp pour l'activation.</li>
				</ol>
				<p>Une fois activé, redémarrez l'application et profitez de vos chaînes !</p>
			`
		},
		{
			slug: "meilleures-apps-android",
			title: "Meilleures applications IPTV pour Android en 2024",
			content: `
				<h2>Pourquoi Android ?</h2>
				<p>Android est la plateforme la plus flexible pour l'IPTV. Voici les meilleures apps :</p>
				<ul>
					<li><strong>IPTV Smarters Pro :</strong> La référence absolue en termes d'interface.</li>
					<li><strong>TiviMate :</strong> La meilleure expérience type "décodeur" traditionnel.</li>
					<li><strong>XCIPTV :</strong> Simple, robuste et très stable.</li>
				</ul>
				<p>Contactez notre support pour obtenir vos identifiants de connexion.</p>
			`
		},
		{
			slug: "eviter-freezes-iptv",
			title: "Comment éviter les freezes sur IPTV ?",
			content: `
				<h2>Conseils de stabilité</h2>
				<p>Le freeze est souvent lié à la connexion locale plutôt qu'au serveur. Voici comment l'éviter :</p>
				<ul>
					<li><strong>Utilisez un câble Ethernet :</strong> Évitez le Wi-Fi si possible pour une latence minimale.</li>
					<li><strong>Redémarrez votre box :</strong> Une simple réinitialisation du routeur peut résoudre 80% des problèmes.</li>
					<li><strong>Changez de lecteur :</strong> Parfois, changer d'application peut améliorer la fluidité.</li>
				</ul>
			`
		}
	];
	return guides.map((guide) => ({
		params: { slug: guide.slug },
		props: { guide },
	}));
}

const { guide } = Astro.props;
---

<Layout title={`${guide.title} - Abonnement IPTV`} description={`Apprenez comment : ${guide.title}. Notre guide complet pour les utilisateurs en France.`}>
	<article class="py-20 bg-white">
		<div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
			<a href="/guides" class="text-sm font-bold text-brand-blue hover:underline">← Retour aux guides</a>
			<h1 class="mt-8 text-4xl font-extrabold text-slate-900">{guide.title}</h1>
			<div class="prose prose-slate mt-10 max-w-none prose-headings:text-slate-900 prose-headings:font-bold prose-strong:text-brand-blue" set:html={guide.content} />
			
			<!-- Permanent Promotional Banner -->
			<div class="mt-16 rounded-2xl bg-brand-blue p-8 text-white text-center">
				<h3 class="text-2xl font-bold">Besoin d'un abonnement stable ?</h3>
				<p class="mt-2 text-blue-100">Profitez du meilleur service IPTV Premium avec Abonnement IPTV.</p>
				<a href="/#pricing" class="mt-6 inline-block rounded-xl bg-white px-8 py-3 font-bold text-brand-blue hover:bg-blue-50">
					Voir nos offres
				</a>
			</div>
		</div>
	</article>
</Layout>

<style is:global>
	.prose h2 { font-size: 1.5rem; margin-top: 3rem; margin-bottom: 1rem; font-weight: 700; color: #0f172a; }
	.prose p { color: #475569; margin-bottom: 1.5rem; line-height: 1.625; }
	.prose ul, .prose ol { margin-bottom: 1.5rem; margin-left: 1.5rem; list-style-type: disc; }
	.prose li { margin-bottom: 0.5rem; color: #475569; }
</style>

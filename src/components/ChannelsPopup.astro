            <button id="maybe-later" class="mt-6 text-sm text-slate-400 hover:text-slate-600 transition">Peut-être plus tard</button>
        </div>
    </div>
</div>

<script>
    const popup = document.getElementById('channels-popup');
    const content = document.getElementById('popup-content');
    const closeBtn = document.getElementById('close-popup');
    const laterBtn = document.getElementById('maybe-later');

    const showPopup = () => {
        popup.classList.remove('opacity-0', 'pointer-events-none');
        content.classList.remove('scale-90');
        content.classList.add('scale-100');
    };

    const hidePopup = () => {
        popup.classList.add('opacity-0', 'pointer-events-none');
        content.classList.remove('scale-100');
        content.classList.add('scale-90');
        localStorage.setItem('popup-closed', 'true');
    };

    if (!localStorage.getItem('popup-closed')) {
        setTimeout(showPopup, 5000); // Show after 5 seconds
    }

    closeBtn.addEventListener('click', hidePopup);
    laterBtn.addEventListener('click', hidePopup);
    popup.addEventListener('click', (e) => {
        if (e.target === popup) hidePopup();
    });
</script>
